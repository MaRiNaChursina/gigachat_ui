# Опционально: для сборки под GitHub Pages в подкаталоге, например /frontend/
# VITE_BASE_PATH=/frontend/

# --- GigaChat API (см. «Подключение GigaChat в свой проект») ---
#
# Шаг 1. Access token: POST https://ngw.devices.sberbank.ru:9443/api/v2/oauth
# В заголовке Authorization: Basic <Authorization key>
#
# VITE_GIGACHAT_AUTHORIZATION_KEY — это только значение <Authorization key>
# (без слова "Basic " и без пробела). Его выдаёт личный кабинет GigaChat; часто это
# Base64 от строки "Client ID:Client Secret" в одну строку без переносов.
#
# Шаг 2. Запросы к API (чат, модели): https://gigachat.devices.sberbank.ru/
# с Authorization: Bearer <Access token> — токен приложение получает сам при каждом
# обращении (он живёт ~30 минут, при следующем сообщении снова запросит OAuth).
#
VITE_GIGACHAT_AUTHORIZATION_KEY=

# Область OAuth, как в --data-urlencode 'scope=...' (персональный API по умолчанию).
VITE_GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Опционально: полный URL внешнего backend-прокси GigaChat
# (приоритетнее локального __proxy и /api/gigachat), например:
# VITE_GIGACHAT_PROXY_BASE=https://your-app.vercel.app/api/gigachat
